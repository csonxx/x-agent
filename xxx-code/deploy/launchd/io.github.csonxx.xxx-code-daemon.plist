<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "https://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.github.csonxx.xxx-code-daemon</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/xxx-code</string>
    <string>--daemon</string>
    <string>--config</string>
    <string>/usr/local/etc/xxx-code/config.yaml</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/usr/local/var/lib/xxx-code</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>/usr/local/var/lib/xxx-code</string>
  </dict>

  <key>KeepAlive</key>
  <true/>

  <key>RunAtLoad</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>5</integer>

  <key>StandardOutPath</key>
  <string>/usr/local/var/log/xxx-code/stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/usr/local/var/log/xxx-code/stderr.log</string>
</dict>
</plist>
