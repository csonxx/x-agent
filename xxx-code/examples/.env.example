# Shared provider switch used by xxx-code when you want env-driven config.
XXX_CODE_PROVIDER=anthropic
# Model or deployment name when not set in YAML.
XXX_CODE_MODEL=claude-sonnet-4-5
# Optional explicit provider base URL override.
XXX_CODE_BASE_URL=
# Optional generic API key override; provider-specific keys below are preferred when present.
XXX_CODE_API_KEY=

# Working directory used by the runtime and tool permissions.
XXX_CODE_CWD=.
# Session transcript persistence path.
XXX_CODE_SESSION_FILE=.xxx-code/session.json
# Optional extra diagnostics output file.
XXX_CODE_LOG_FILE=.xxx-code/xxx-code.log
# Optional diagnostics level: error, info, debug.
XXX_CODE_LOG_LEVEL=info
# Optional event sink for hook JSONL output.
XXX_CODE_HOOK_EVENT_FILE=.xxx-code/hooks/events.jsonl
# Optional plugin directory override.
XXX_CODE_PLUGIN_DIR=.xxx-code/plugins
# Optional MCP config path override.
XXX_CODE_MCP_CONFIG=.mcp.json

# Anthropic API key.
ANTHROPIC_API_KEY=
# Optional Anthropic API base URL.
ANTHROPIC_BASE_URL=
# Optional Anthropic API version header.
ANTHROPIC_VERSION=2023-06-01

# OpenAI or GPT API key.
OPENAI_API_KEY=
# Optional OpenAI-compatible base URL.
OPENAI_BASE_URL=

# Azure OpenAI API key.
AZURE_OPENAI_API_KEY=
# Azure OpenAI resource root or /openai/v1 base URL.
AZURE_OPENAI_BASE_URL=

# Gemini API key for Google's OpenAI-compatible endpoint.
GEMINI_API_KEY=
# Optional Gemini base URL override.
GEMINI_BASE_URL=

# MiniMax API key.
MINIMAX_API_KEY=
# Optional MiniMax base URL override.
MINIMAX_BASE_URL=

# GLM API key.
GLM_API_KEY=
# Zhipu compatibility API key alias.
ZHIPUAI_API_KEY=
# BigModel compatibility API key alias.
BIGMODEL_API_KEY=
# Z.ai compatibility API key alias.
ZAI_API_KEY=
# Optional GLM base URL override.
GLM_BASE_URL=
