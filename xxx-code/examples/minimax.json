  "daemon_dir": ".xxx-code/daemon",
  "daemon_token_file": ".secrets/daemon-token.txt",
  "daemon_audit_file": ".xxx-code/daemon/audit.jsonl",
  "daemon_rate_limit_per_minute": 120,
  "daemon_rate_limit_burst": 20,
  "daemon_allow_modes": [
